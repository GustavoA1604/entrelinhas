{
  "name": "entrelinhas",
  "version": "1.2.0",
  "description": "Versão em português brasileiro do Betweenle, com modo clássico e palavras cruzadas.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "homepage": "https://gustavoa1604.github.io/entrelinhas/",
  "scripts": {
    "serve": "node scripts/serve.js 8000",
    "gen:data": "node scripts/gen-data.js",
    "gen:trivia": "node scripts/gen-trivia-stats.js",
    "gen": "npm run gen:data && npm run gen:trivia",
    "bump:version": "node scripts/bump-version.js",
    "test": "node --test",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
